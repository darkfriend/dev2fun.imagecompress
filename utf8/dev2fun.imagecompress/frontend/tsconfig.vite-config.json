{
    "include": [
        "vite.config.*"
    ],
    "compilerOptions": {
        "composite": true,
        "target": "ES2022",
        "lib": [
            "ES2023"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ]
    }
}
